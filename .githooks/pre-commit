#!/usr/bin/env bash
# turbo-surf pre-commit gate. The engine is Rust (see rust/ — gated by `cargo test
# / clippy / fmt`, run via `npm run check`). The only JS left is the thin launcher
# (cli.js/index.js) + the dev harness, so this hook just lints/formats staged JS.
# Enable once with:  git config core.hooksPath .githooks  (or: npm run prepare)
set -uo pipefail

ROOT="$(git rev-parse --show-toplevel)"
cd "$ROOT" || exit 1

status=0
fail() { echo "  ✖ $1"; status=1; }

# Vendored files are byte-for-byte upstream copies (the turbo-test DOM binding
# `browser_env.js`) — never lint/reformat them (re-vendoring overwrites them, and
# oxlint/biome ignore configs don't apply to explicitly-passed paths, so filter here).
VENDORED='(^|/)browser_env\.js$'
staged="$(git diff --cached --name-only --diff-filter=ACM | grep -vE "$VENDORED" || true)"
js_files="$(echo "$staged"  | grep -E '\.(mjs|js|cjs)$'             || true)"
fmt_files="$(echo "$staged" | grep -E '\.(mjs|js|cjs|json|jsonc)$' || true)"

have() { command -v "$1" >/dev/null 2>&1; }
runjs() { if have npx; then npx --no-install "$@"; else return 127; fi; }

if [ -n "$js_files" ] || [ -n "$fmt_files" ]; then
  echo "• JS gates"
  # 1. oxlint
  if [ -n "$js_files" ]; then
    runjs oxlint $js_files || fail "oxlint reported problems"
  fi
  # 2. biome format (auto-fix, then re-stage)
  if [ -n "$fmt_files" ]; then
    if runjs biome format --write $fmt_files; then
      echo "$fmt_files" | xargs git add
    else
      fail "biome formatting failed"
    fi
  fi
fi

if [ "$status" -ne 0 ]; then
  echo "✖ pre-commit gate failed. Fix the above and re-commit."
fi
exit "$status"
