{
  "name": "@miaskiewicz/turbo-crawl",
  "version": "0.2.0",
  "description": "Native-speed, browserless web crawler + MCP server for AI agents. A standalone Rust engine (turbo-dom + a V8 JS-render tier) — fetch + parse + extract + run page JS with no headless browser. This npm package is a thin launcher that spawns the native binary.",
  "license": "MIT",
  "main": "index.js",
  "exports": {
    ".": "./index.js",
    "./package.json": "./package.json"
  },
  "bin": {
    "turbo-crawl-mcp": "cli.js"
  },
  "files": ["bin", "cli.js", "index.js", "LICENSE", "README.md", "CHANGELOG.md"],
  "scripts": {
    "lint": "oxlint",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "check": "npm run lint && npm run format:check && cd rust && cargo test --workspace && cargo clippy --workspace --all-targets -- -D warnings && cargo fmt --check",
    "prepare": "git config core.hooksPath .githooks || true",
    "harness": "node harness/competitive/run.mjs",
    "harness:js": "node harness/competitive/run.mjs js-quotes",
    "hotpath": "node harness/hotpath/rust-hotpath.mjs",
    "crawl-bench": "node harness/crawlers/run.mjs",
    "crawl-bench:js": "node harness/crawlers/run.mjs --set=js"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "crawler",
    "scraper",
    "web-crawler",
    "agent",
    "llm",
    "mcp",
    "turbo-dom",
    "headless",
    "browserless",
    "extraction",
    "rust",
    "fast"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/miaskiewicz/turbo-crawl.git"
  },
  "homepage": "https://github.com/miaskiewicz/turbo-crawl#readme",
  "bugs": {
    "url": "https://github.com/miaskiewicz/turbo-crawl/issues"
  },
  "author": "miaskiewicz",
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.0",
    "oxlint": "^0.11.0",
    "playwright": "^1.61.0"
  }
}
