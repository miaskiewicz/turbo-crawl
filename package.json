{
  "name": "turbo-surf",
  "version": "0.2.5",
  "description": "Native-speed, browserless web crawler + MCP server for AI agents. A standalone Rust engine (turbo-dom + a V8 JS-render tier) — fetch + parse + extract + run page JS with no headless browser. This npm package is a thin launcher that spawns the native binary.",
  "license": "MIT",
  "main": "index.js",
  "exports": {
    ".": "./index.js",
    "./package.json": "./package.json"
  },
  "bin": {
    "turbo-surf-mcp": "cli.js"
  },
  "files": ["bin", "cli.js", "index.js", "LICENSE", "README.md", "CHANGELOG.md"],
  "scripts": {
    "lint": "oxlint",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "build:addon": "cd rust && cargo build --release -p turbo-surf-napi",
    "test:shim": "node --test --test-concurrency=1 rust/playwright-shim/test.mjs rust/playwright-shim/surface.test.mjs",
    "test:e2e": "node --import ./rust/playwright-shim/register.mjs --test --test-concurrency=1 rust/playwright-shim/dropin.spec.mjs rust/playwright-shim/e2e/*.spec.mjs",
    "test:playwright": "npm run build:addon && npm run test:shim && npm run test:e2e",
    "test": "(cd rust && cargo test --workspace && cargo clippy --workspace --all-targets -- -D warnings && cargo fmt --check) && npm run test:playwright",
    "check": "npm run lint && npm run format:check && npm test",
    "prepare": "git config core.hooksPath .githooks || true",
    "harness": "node harness/competitive/run.mjs",
    "harness:js": "node harness/competitive/run.mjs js-quotes",
    "hotpath": "node harness/hotpath/rust-hotpath.mjs",
    "hotpath:render": "node harness/hotpath/render-bench.mjs",
    "crawl-bench": "node harness/crawlers/run.mjs",
    "crawl-bench:js": "node harness/crawlers/run.mjs --set=js"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "crawler",
    "scraper",
    "web-crawler",
    "agent",
    "llm",
    "mcp",
    "turbo-dom",
    "headless",
    "browserless",
    "extraction",
    "rust",
    "fast"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/miaskiewicz/turbo-surf.git"
  },
  "homepage": "https://github.com/miaskiewicz/turbo-surf#readme",
  "bugs": {
    "url": "https://github.com/miaskiewicz/turbo-surf/issues"
  },
  "author": "miaskiewicz",
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.0",
    "oxlint": "^0.11.0",
    "playwright": "^1.61.0"
  }
}
