# turbo-surf challenge-solver config (optional).
#
# Copy to `.env` and fill in a real key to enable solving JS-challenge / PoW WAFs
# (Akamai, DataDome, Kasada, Cloudflare). With no real key set, the solver is
# inert and turbo-surf behaves exactly as before. Placeholder values below are
# recognised as "unset" (see turbo-surf-core::challenge).
#
# `.env` is gitignored — never commit real keys.

# Which solver to use:
#   cloudflare | awswaf | akamai  — in-house, no key (run the challenge JS in V8;
#                                   akamai is experimental). All fall back to the
#                                   browser sidecar below if their self-solve fails.
#   hyper | scrapfly              — rented token APIs (need the key below)
#   browser                       — self-owned hardened-headless sidecar (cmd below)
# Unset = no solving (fingerprint only); for hyper/scrapfly, first key present wins.
TURBO_SURF_SOLVER=

# Hyper Solutions (server-side token gen, no browser): Akamai / DataDome / Kasada.
# https://hypersolutions.co
HYPER_API_KEY=your_hyper_api_key_here

# Scrapfly ASP (rendered + residential proxy): Cloudflare + fallback for the rest.
# https://scrapfly.io
SCRAPFLY_API_KEY=your_scrapfly_api_key_here

# Hardened-headless sidecar command for solver=browser. Also enables the Akamai
# browser fallback (solver=akamai tries in-house, then this).
TURBO_SURF_BROWSER_CMD=

# Where analyze_akamai's `retry` saves a working sensor (default: akamai-sensors).
TURBO_SURF_SENSOR_DIR=

# Egress proxy for IP/JA3 pinning. Solver tokens are bound to the IP that made
# them — replay through the SAME proxy or the token is rejected.
# Format: http://user:pass@host:port
TURBO_SURF_PROXY=
