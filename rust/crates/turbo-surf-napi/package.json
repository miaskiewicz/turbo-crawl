{
  "name": "turbo-surf-native",
  "version": "0.2.4",
  "description": "Native (Rust) engine for turbo-surf — napi-rs addon",
  "main": "index.js",
  "types": "index.d.ts",
  "license": "MIT",
  "repository": "github:miaskiewicz/turbo-surf",
  "files": ["index.js", "index.d.ts", "turbo-surf.*.node"],
  "napi": {
    "name": "turbo-surf",
    "triples": {
      "defaults": true,
      "additional": [
        "aarch64-apple-darwin",
        "aarch64-unknown-linux-gnu",
        "x86_64-unknown-linux-gnu"
      ]
    }
  },
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "napi build --platform --release --cargo-cwd .",
    "test": "node __test__/smoke.cjs"
  },
  "devDependencies": {
    "@napi-rs/cli": "^2.18.0"
  }
}
